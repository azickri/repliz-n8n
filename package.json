{
  "name": "n8n-nodes-repliz",
  "version": "1.0.7",
  "description": "n8n community nodes for Repliz API — manage accounts, comments, chats, content, schedules, and platform addons.",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/azickri/repliz-n8n#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/azickri/repliz-n8n.git"
  },
  "bugs": {
    "url": "https://github.com/azickri/repliz-n8n/issues"
  },
  "author": "Azickri <contact.azickri@gmail.com>",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ReplizApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ReplizAccount/ReplizAccount.node.js",
      "dist/nodes/ReplizAccountFacebook/ReplizAccountFacebook.node.js",
      "dist/nodes/ReplizAccountInstagram/ReplizAccountInstagram.node.js",
      "dist/nodes/ReplizAccountThreads/ReplizAccountThreads.node.js",
      "dist/nodes/ReplizAccountYoutube/ReplizAccountYoutube.node.js",
      "dist/nodes/ReplizAccountLinkedIn/ReplizAccountLinkedIn.node.js",
      "dist/nodes/ReplizAccountTikTok/ReplizAccountTikTok.node.js",
      "dist/nodes/ReplizAccountShopee/ReplizAccountShopee.node.js",
      "dist/nodes/ReplizComment/ReplizComment.node.js",
      "dist/nodes/ReplizChat/ReplizChat.node.js",
      "dist/nodes/ReplizContent/ReplizContent.node.js",
      "dist/nodes/ReplizSchedule/ReplizSchedule.node.js",
      "dist/nodes/ReplizResearch/ReplizResearch.node.js",
      "dist/nodes/ReplizAddon/ReplizAddon.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  }
}